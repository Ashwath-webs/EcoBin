<!DOCTYPE html>
<html>

<head>

    <title>Edit Product</title>

    <meta charset="UTF-8">

    <meta name="viewport"
          content="width=device-width, initial-scale=1.0">

    <link rel="stylesheet"
          href="../css/style.css">

</head>

<body class="auth-body">

<div class="form-container">

    <h2>
        Edit Product
    </h2>

    <form>

        <input type="text"
               value="Dell Inspiron Laptop">

        <input type="text"
               value="Laptop">

        <textarea style="
                  width:100%;
                  margin-top:15px;
                  padding:15px;
                  border:none;
                  border-radius:14px;
                  background:rgba(255,255,255,0.06);
                  color:white;
                  height:120px;
                  ">Premium refurbished laptop</textarea>

        <input type="number"
               value="18500">

        <input type="number"
               value="5">

        <button type="submit">

            Update Product

        </button>

    </form>

</div>

</body>
</html>